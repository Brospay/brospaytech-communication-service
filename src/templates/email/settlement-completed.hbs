<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Settlement Completed - ZenPay</title>
</head>
<body style="margin: 0; padding: 0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f5f7fa;">
  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #f5f7fa; padding: 40px 20px;">
    <tr>
      <td align="center">
        <table width="600" cellpadding="0" cellspacing="0" border="0" style="background-color: #ffffff; border-radius: 12px; box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);">
          <tr>
            <td style="padding: 40px 40px 30px; text-align: center; background: linear-gradient(135deg, #805ad5 0%, #6b46c1 100%); border-radius: 12px 12px 0 0;">
              <h1 style="margin: 0; color: #ffffff; font-size: 28px; font-weight: 600;">Settlement Completed</h1>
            </td>
          </tr>
          
          <tr>
            <td style="padding: 40px;">
              <p style="margin: 0 0 20px; color: #2d3748; font-size: 16px; line-height: 1.6;">
                Hi <strong>{{merchant_name}}</strong>,
              </p>
              
              <p style="margin: 0 0 20px; color: #2d3748; font-size: 16px; line-height: 1.6;">
                Your settlement for {{settlement_period}} has been processed and transferred to your registered bank account.
              </p>
              
              <div style="background-color: #f7fafc; padding: 20px; margin: 24px 0; border-radius: 8px;">
                <table width="100%" cellpadding="8" cellspacing="0" border="0">
                  <tr>
                    <td style="color: #718096; font-size: 14px; padding: 8px 0;">Settlement ID</td>
                    <td style="color: #2d3748; font-size: 14px; font-weight: 600; text-align: right; padding: 8px 0;">{{settlement_id}}</td>
                  </tr>
                  <tr>
                    <td style="color: #718096; font-size: 14px; padding: 8px 0; border-top: 1px solid #e2e8f0;">Settlement Amount</td>
                    <td style="color: #2d3748; font-size: 20px; font-weight: 700; text-align: right; padding: 8px 0; border-top: 1px solid #e2e8f0;">{{formatCurrency settlement_amount currency}}</td>
                  </tr>
                  <tr>
                    <td style="color: #718096; font-size: 14px; padding: 8px 0; border-top: 1px solid #e2e8f0;">Total Transactions</td>
                    <td style="color: #2d3748; font-size: 14px; font-weight: 600; text-align: right; padding: 8px 0; border-top: 1px solid #e2e8f0;">{{transaction_count}}</td>
                  </tr>
                  <tr>
                    <td style="color: #718096; font-size: 14px; padding: 8px 0; border-top: 1px solid #e2e8f0;">Settlement Period</td>
                    <td style="color: #2d3748; font-size: 14px; font-weight: 600; text-align: right; padding: 8px 0; border-top: 1px solid #e2e8f0;">{{settlement_period}}</td>
                  </tr>
                  <tr>
                    <td style="color: #718096; font-size: 14px; padding: 8px 0; border-top: 1px solid #e2e8f0;">Settlement Date</td>
                    <td style="color: #2d3748; font-size: 14px; font-weight: 600; text-align: right; padding: 8px 0; border-top: 1px solid #e2e8f0;">{{formatDateTime settlement_date}}</td>
                  </tr>
                  <tr>
                    <td style="color: #718096; font-size: 14px; padding: 8px 0; border-top: 1px solid #e2e8f0;">Bank Account</td>
                    <td style="color: #2d3748; font-size: 14px; font-weight: 600; text-align: right; padding: 8px 0; border-top: 1px solid #e2e8f0;">{{masked_account_number}}</td>
                  </tr>
                </table>
              </div>
              
              <div style="background-color: #f0f4ff; padding: 20px; margin: 24px 0; border-radius: 8px;">
                <p style="margin: 0 0 12px; color: #434190; font-size: 14px; font-weight: 600;">
                  Breakdown:
                </p>
                <table width="100%" cellpadding="4" cellspacing="0" border="0">
                  <tr>
                    <td style="color: #5a67d8; font-size: 13px; padding: 4px 0;">Gross Amount</td>
                    <td style="color: #434190; font-size: 13px; font-weight: 600; text-align: right; padding: 4px 0;">{{formatCurrency gross_amount currency}}</td>
                  </tr>
                  <tr>
                    <td style="color: #5a67d8; font-size: 13px; padding: 4px 0;">Processing Fees</td>
                    <td style="color: #434190; font-size: 13px; font-weight: 600; text-align: right; padding: 4px 0;">- {{formatCurrency fees currency}}</td>
                  </tr>
                  {{#if adjustments}}
                  <tr>
                    <td style="color: #5a67d8; font-size: 13px; padding: 4px 0;">Adjustments</td>
                    <td style="color: #434190; font-size: 13px; font-weight: 600; text-align: right; padding: 4px 0;">{{formatCurrency adjustments currency}}</td>
                  </tr>
                  {{/if}}
                  <tr>
                    <td style="color: #5a67d8; font-size: 14px; padding: 8px 0 4px; border-top: 1px solid #c3dafe; font-weight: 600;">Net Settlement</td>
                    <td style="color: #434190; font-size: 14px; font-weight: 700; text-align: right; padding: 8px 0 4px; border-top: 1px solid #c3dafe;">{{formatCurrency settlement_amount currency}}</td>
                  </tr>
                </table>
              </div>
              
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin: 32px 0;">
                <tr>
                  <td align="center">
                    <a href="{{view_report_url}}" style="display: inline-block; padding: 14px 32px; background: linear-gradient(135deg, #805ad5 0%, #6b46c1 100%); color: #ffffff; text-decoration: none; border-radius: 8px; font-weight: 600; font-size: 16px;">
                      View Detailed Report
                    </a>
                  </td>
                </tr>
              </table>
              
              <p style="margin: 24px 0 0; color: #718096; font-size: 14px; line-height: 1.6;">
                The funds will be credited to your account within 1-2 business days depending on your bank.
              </p>
            </td>
          </tr>
          
          <tr>
            <td style="padding: 30px 40px; background-color: #f7fafc; border-radius: 0 0 12px 12px; border-top: 1px solid #e2e8f0;">
              <p style="margin: 0 0 12px; color: #718096; font-size: 13px; line-height: 1.6; text-align: center;">
                Questions? Contact <a href="mailto:settlements@zenpay.com" style="color: #667eea; text-decoration: none;">settlements@zenpay.com</a>
              </p>
              <p style="margin: 0; color: #a0aec0; font-size: 12px; text-align: center;">
                © {{year}} ZenPay. All rights reserved.
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>

