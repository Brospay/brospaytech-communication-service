<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Security Alert - ZenPay</title>
</head>
<body style="margin: 0; padding: 0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f5f7fa;">
  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #f5f7fa; padding: 40px 20px;">
    <tr>
      <td align="center">
        <table width="600" cellpadding="0" cellspacing="0" border="0" style="background-color: #ffffff; border-radius: 12px; box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);">
          <tr>
            <td style="padding: 40px 40px 30px; text-align: center; background: linear-gradient(135deg, #f56565 0%, #e53e3e 100%); border-radius: 12px 12px 0 0;">
              <h1 style="margin: 0; color: #ffffff; font-size: 28px; font-weight: 600;">Security Alert</h1>
            </td>
          </tr>
          
          <tr>
            <td style="padding: 40px;">
              <p style="margin: 0 0 20px; color: #2d3748; font-size: 16px; line-height: 1.6;">
                Hi <strong>{{user_name}}</strong>,
              </p>
              
              <p style="margin: 0 0 20px; color: #2d3748; font-size: 16px; line-height: 1.6;">
                We detected {{alert_type}} activity on your ZenPay account. Please review the details below.
              </p>
              
              <div style="background-color: #fff5f5; border-left: 4px solid #f56565; padding: 16px; margin: 24px 0; border-radius: 4px;">
                <p style="margin: 0 0 8px; color: #c53030; font-size: 14px; font-weight: 600;">
                  {{alert_title}}
                </p>
                <p style="margin: 0; color: #742a2a; font-size: 14px; line-height: 1.6;">
                  {{alert_description}}
                </p>
              </div>
              
              <div style="background-color: #f7fafc; padding: 20px; margin: 24px 0; border-radius: 8px;">
                <table width="100%" cellpadding="8" cellspacing="0" border="0">
                  <tr>
                    <td style="color: #718096; font-size: 14px; padding: 8px 0;">Activity</td>
                    <td style="color: #2d3748; font-size: 14px; font-weight: 600; text-align: right; padding: 8px 0;">{{activity_type}}</td>
                  </tr>
                  <tr>
                    <td style="color: #718096; font-size: 14px; padding: 8px 0; border-top: 1px solid #e2e8f0;">Date & Time</td>
                    <td style="color: #2d3748; font-size: 14px; font-weight: 600; text-align: right; padding: 8px 0; border-top: 1px solid #e2e8f0;">{{formatDateTime activity_time}}</td>
                  </tr>
                  {{#if ip_address}}
                  <tr>
                    <td style="color: #718096; font-size: 14px; padding: 8px 0; border-top: 1px solid #e2e8f0;">IP Address</td>
                    <td style="color: #2d3748; font-size: 14px; font-weight: 600; text-align: right; padding: 8px 0; border-top: 1px solid #e2e8f0;">{{ip_address}}</td>
                  </tr>
                  {{/if}}
                  {{#if location}}
                  <tr>
                    <td style="color: #718096; font-size: 14px; padding: 8px 0; border-top: 1px solid #e2e8f0;">Location</td>
                    <td style="color: #2d3748; font-size: 14px; font-weight: 600; text-align: right; padding: 8px 0; border-top: 1px solid #e2e8f0;">{{location}}</td>
                  </tr>
                  {{/if}}
                  {{#if device}}
                  <tr>
                    <td style="color: #718096; font-size: 14px; padding: 8px 0; border-top: 1px solid #e2e8f0;">Device</td>
                    <td style="color: #2d3748; font-size: 14px; font-weight: 600; text-align: right; padding: 8px 0; border-top: 1px solid #e2e8f0;">{{device}}</td>
                  </tr>
                  {{/if}}
                </table>
              </div>
              
              {{#if (eq action_required true)}}
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin: 32px 0;">
                <tr>
                  <td align="center">
                    <a href="{{action_url}}" style="display: inline-block; padding: 14px 32px; background: linear-gradient(135deg, #f56565 0%, #e53e3e 100%); color: #ffffff; text-decoration: none; border-radius: 8px; font-weight: 600; font-size: 16px;">
                      Secure My Account
                    </a>
                  </td>
                </tr>
              </table>
              {{/if}}
              
              <p style="margin: 24px 0 8px; color: #2d3748; font-size: 14px; font-weight: 600;">
                What to do:
              </p>
              <ul style="margin: 8px 0; padding-left: 20px; color: #4a5568; font-size: 14px; line-height: 1.8;">
                <li>If this was you, no action is needed</li>
                <li>If you don't recognize this activity, secure your account immediately</li>
                <li>Change your password if you suspect unauthorized access</li>
                <li>Review recent account activity</li>
                <li>Contact support if you need assistance</li>
              </ul>
              
              <p style="margin: 24px 0 0; color: #718096; font-size: 14px; line-height: 1.6;">
                We take your security seriously. This is an automated alert to help protect your account.
              </p>
            </td>
          </tr>
          
          <tr>
            <td style="padding: 30px 40px; background-color: #f7fafc; border-radius: 0 0 12px 12px; border-top: 1px solid #e2e8f0;">
              <p style="margin: 0 0 12px; color: #718096; font-size: 13px; line-height: 1.6; text-align: center;">
                Need help? Contact <a href="mailto:security@zenpay.com" style="color: #667eea; text-decoration: none;">security@zenpay.com</a>
              </p>
              <p style="margin: 0; color: #a0aec0; font-size: 12px; text-align: center;">
                © {{year}} ZenPay. All rights reserved.
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>

