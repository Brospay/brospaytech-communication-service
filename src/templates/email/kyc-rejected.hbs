<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>KYC Verification Update - ZenPay</title>
</head>
<body style="margin: 0; padding: 0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f5f7fa;">
  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #f5f7fa; padding: 40px 20px;">
    <tr>
      <td align="center">
        <table width="600" cellpadding="0" cellspacing="0" border="0" style="background-color: #ffffff; border-radius: 12px; box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);">
          <tr>
            <td style="padding: 40px 40px 30px; text-align: center; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 12px 12px 0 0;">
              <h1 style="margin: 0; color: #ffffff; font-size: 28px; font-weight: 600;">KYC Verification Update</h1>
            </td>
          </tr>
          
          <tr>
            <td style="padding: 40px;">
              <p style="margin: 0 0 20px; color: #2d3748; font-size: 16px; line-height: 1.6;">
                Hi <strong>{{merchant_name}}</strong>,
              </p>
              
              <p style="margin: 0 0 20px; color: #2d3748; font-size: 16px; line-height: 1.6;">
                We've reviewed your KYC documents and need additional information to complete the verification process.
              </p>
              
              <div style="background-color: #fffaf0; border-left: 4px solid #ed8936; padding: 16px; margin: 24px 0; border-radius: 4px;">
                <p style="margin: 0 0 12px; color: #c05621; font-size: 14px; font-weight: 600;">
                  Required Actions:
                </p>
                <p style="margin: 0; color: #744210; font-size: 14px; line-height: 1.6;">
                  {{rejection_reason}}
                </p>
              </div>
              
              {{#if required_documents}}
              <p style="margin: 24px 0 8px; color: #2d3748; font-size: 14px; font-weight: 600;">
                Please provide:
              </p>
              <ul style="margin: 8px 0; padding-left: 20px; color: #4a5568; font-size: 14px; line-height: 1.8;">
                {{#each required_documents}}
                <li>{{this}}</li>
                {{/each}}
              </ul>
              {{/if}}
              
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin: 32px 0;">
                <tr>
                  <td align="center">
                    <a href="{{resubmit_url}}" style="display: inline-block; padding: 14px 32px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: #ffffff; text-decoration: none; border-radius: 8px; font-weight: 600; font-size: 16px;">
                      Resubmit Documents
                    </a>
                  </td>
                </tr>
              </table>
              
              <p style="margin: 24px 0 0; color: #718096; font-size: 14px; line-height: 1.6;">
                Our compliance team will review your updated submission within 24-48 hours.
              </p>
            </td>
          </tr>
          
          <tr>
            <td style="padding: 30px 40px; background-color: #f7fafc; border-radius: 0 0 12px 12px; border-top: 1px solid #e2e8f0;">
              <p style="margin: 0 0 12px; color: #718096; font-size: 13px; line-height: 1.6; text-align: center;">
                Questions? Contact <a href="mailto:compliance@zenpay.com" style="color: #667eea; text-decoration: none;">compliance@zenpay.com</a>
              </p>
              <p style="margin: 0; color: #a0aec0; font-size: 12px; text-align: center;">
                © {{year}} ZenPay. All rights reserved.
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>

